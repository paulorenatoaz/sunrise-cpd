  "detector_aggregation": "mean_z",
  "detector_aggregation_description": "At each timestamp, compute the per-sensor standardized evidence z_{i,t} = (x_{i,t} - mu_{0,i}) / sigma_{0,i} for each active sensor with a usable baseline, then average over the active sensors that report a finite reading. Apply the one-sided Page CUSUM to this aggregated evidence.",
  "detector_parameters": {
    "drift_k": 0.5,
    "min_baseline_samples": 5,
    "fallback_sigma": 1.0,
    "formula": "z_{i,t} = (x_{i,t} - mu_{0,i})/sigma_{0,i}; Z_t = mean_{i in S_t} z_{i,t}; S_t = max(0, S_{t-1} + Z_t - k); detect when S_t >= h."
